{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-config-schema/refs/heads/main/schema.json",
  "productName": "Productivity App",
  "version": "0.1.0",
  "identifier": "com.productivity-app.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Productivity App",
        "width": 900,
        "height": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
